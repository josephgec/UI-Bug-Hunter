{
  "name": "ui-bug-hunter",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "web:dev": "pnpm --filter @ubh/web dev",
    "worker:dev": "pnpm --filter @ubh/worker dev",
    "db:generate": "pnpm --filter @ubh/db generate",
    "db:migrate": "pnpm --filter @ubh/db migrate",
    "db:studio": "pnpm --filter @ubh/db studio",
    "eval": "pnpm --filter @ubh/eval run"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.0",
    "ioredis-mock": "^8.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
