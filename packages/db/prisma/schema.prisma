// UI Bug Hunter — Phase 1 schema.
// Mirrors §7 of the design doc. Flow / multi-step support is deferred to Phase 3
// but the relation column is left out rather than stubbed to avoid a column we
// don't read yet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("free")
  createdAt DateTime @default(now())

  projects Project[]
  users    User[]
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  feedback  Feedback[]
  createdAt DateTime   @default(now())
}

model Project {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  baseUrl   String
  viewports String[] @default(["desktop"])
  createdAt DateTime @default(now())

  scans Scan[]

  @@index([orgId])
}

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model Scan {
  id           String     @id @default(cuid())
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status       ScanStatus @default(QUEUED)
  targetUrl    String
  viewport     String     @default("desktop")
  startedAt    DateTime?
  finishedAt   DateTime?
  costCents    Int        @default(0)
  toolCalls    Int        @default(0)
  errorMessage String?
  createdAt    DateTime   @default(now())

  findings Finding[]

  @@index([projectId, status])
  @@index([status, createdAt])
}

model Finding {
  id                String   @id @default(cuid())
  scanId            String
  scan              Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  category          String
  severity          String
  confidence        Float
  title             String
  description       String
  screenshotUrl     String?
  bbox              Json?
  domSnippet        String?
  reproductionSteps String[] @default([])
  status            String   @default("open")
  createdAt         DateTime @default(now())

  feedback Feedback[]

  @@index([scanId])
  @@index([scanId, category])
}

model Feedback {
  id        String   @id @default(cuid())
  findingId String
  finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verdict   String
  note      String?
  createdAt DateTime @default(now())

  @@index([findingId])
  @@index([userId])
}
