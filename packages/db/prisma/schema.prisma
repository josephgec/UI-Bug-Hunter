// UI Bug Hunter — schema (Phase 3).
// Phase 3 additions: Flow + FlowRun (multi-step user flows), Destination +
// DestinationDispatch (Slack/Linear/Jira routing), AuditLog, OrgMembership +
// Role (RBAC), SsoConnection (SAML/OIDC via WorkOS). Credential gains an
// OAUTH_TOKEN kind with refresh metadata.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  team
  business
  enterprise
}

model Organization {
  id                 String    @id @default(cuid())
  name               String
  plan               Plan      @default(free)
  stripeCustomerId   String?   @unique
  // Quota: number of scan-units (page × viewport) consumed in the current
  // billing period. Reset by the Stripe webhook on invoice.created, or by a
  // monthly cron in dev.
  quotaUsed          Int       @default(0)
  quotaLimit         Int       @default(25)
  quotaResetAt      DateTime  @default(now())
  createdAt          DateTime  @default(now())

  projects       Project[]
  users          User[]
  subscription   Subscription?
  memberships    OrgMembership[]
  ssoConnections SsoConnection[]
  auditLog       AuditLog[]
  destinations   Destination[]
}

enum Role {
  admin
  member
  viewer
}

// Phase 3: explicit org membership table so we can carry per-user role and
// later support multi-org users. The legacy User.orgId still points at the
// "primary" org for back-compat.
model OrgMembership {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @default(member)
  createdAt DateTime @default(now())

  @@unique([orgId, userId])
  @@index([userId])
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  feedback    Feedback[]
  apiTokens   ApiToken[]
  memberships OrgMembership[]
  auditLog    AuditLog[]
  createdAt   DateTime   @default(now())
}

model ApiToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // sha256 of the raw token; raw token shown to user once on creation.
  tokenHash String   @unique
  name      String
  lastUsedAt DateTime?
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Project {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  baseUrl   String
  viewports String[] @default(["desktop"])
  createdAt DateTime @default(now())

  scans        Scan[]
  crawls       Crawl[]
  credentials  Credential[]
  flows        Flow[]
  destinations Destination[]

  @@index([orgId])
}

// Phase 3: multi-step flow definition. The steps array follows the JSON
// shape defined in packages/shared/src/flows.ts. Flows are project-scoped
// because most authentication / setup is per-project.
model Flow {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  steps       Json
  // List of credential ids to inject when running this flow. Resolved by the
  // worker at run time, never stored in plaintext.
  credentialIds String[] @default([])
  // Whether the flow's success requires every step's assertions to pass.
  // (Reserved for week-15 step-level assertions; runner exposes the bit.)
  strictAssertions Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scans Scan[]

  @@index([projectId])
}

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum CrawlStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model Crawl {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  seedUrl     String
  maxDepth    Int         @default(2)
  maxPages    Int         @default(25)
  viewports   String[]    @default(["desktop"])
  status      CrawlStatus @default(QUEUED)
  startedAt   DateTime?
  finishedAt  DateTime?
  pagesScanned Int        @default(0)
  errorMessage String?
  createdAt   DateTime    @default(now())

  scans Scan[]

  @@index([projectId, status])
}

model Scan {
  id            String     @id @default(cuid())
  projectId     String
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  crawlId       String?
  crawl         Crawl?     @relation(fields: [crawlId], references: [id], onDelete: SetNull)
  flowId        String?
  flow          Flow?      @relation(fields: [flowId], references: [id], onDelete: SetNull)
  parentScanId  String?
  depth         Int        @default(0)
  status        ScanStatus @default(QUEUED)
  targetUrl     String
  viewports     String[]   @default(["desktop"])
  startedAt     DateTime?
  finishedAt    DateTime?
  costCents     Int        @default(0)
  toolCalls     Int        @default(0)
  errorMessage  String?
  // Stable hash of (sorted viewports + url) used for crawl-level dedup of
  // identical pages reached via different links.
  fingerprint   String?
  createdAt     DateTime   @default(now())

  findings Finding[]

  @@index([projectId, status])
  @@index([crawlId])
  @@index([flowId])
  @@index([status, createdAt])
}

model Finding {
  id                String   @id @default(cuid())
  scanId            String
  scan              Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  category          String
  severity          String
  confidence        Float
  title             String
  description       String
  screenshotUrl     String?
  bbox              Json?
  domSnippet        String?
  reproductionSteps String[] @default([])
  status            String   @default("open")
  // Used to dedup the same logical bug across pages/viewports of one crawl.
  // Computed as sha256(category + normalized(title) + normalized(domSnippet)).
  dedupHash         String?
  // Phase 3: when this finding came out of a flow, which step (1-indexed)
  // was on screen. Helps the dashboard surface "broken on step 3" context.
  flowStepIndex     Int?
  createdAt         DateTime @default(now())

  feedback   Feedback[]
  dispatches DestinationDispatch[]

  @@index([scanId])
  @@index([scanId, category])
  @@index([dedupHash])
}

model Feedback {
  id        String   @id @default(cuid())
  findingId String
  finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verdict   String
  note      String?
  createdAt DateTime @default(now())

  @@index([findingId])
  @@index([userId])
}

enum CredentialKind {
  HEADER
  COOKIE
  BASIC_AUTH
  OAUTH_TOKEN
}

model Credential {
  id         String         @id @default(cuid())
  projectId  String
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  kind       CredentialKind
  // KMS-encrypted ciphertext (AES-GCM). Plaintext shape depends on kind:
  // HEADER: { name, value }; COOKIE: { name, value, domain }; BASIC_AUTH: { username, password }.
  ciphertext Bytes
  // The KMS provider's identifier for the key used to encrypt — lets us
  // rotate without re-reading every credential.
  keyId      String
  // 12-byte AES-GCM IV stored alongside; auth tag is appended to ciphertext.
  iv         Bytes
  // OAUTH_TOKEN only: refresh metadata so the worker knows when to rotate.
  // refreshAt is the planned rotation time (typically issuedAt + expiresIn -
  // a 5-minute safety margin).
  refreshAt  DateTime?
  createdAt  DateTime       @default(now())
  lastUsedAt DateTime?

  @@unique([projectId, name])
  @@index([projectId])
}

model Subscription {
  id                   String   @id @default(cuid())
  orgId                String   @unique
  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String   // active, past_due, canceled, trialing, ...
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAt             DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ── Phase 3: destinations ────────────────────────────────────────────────────

enum DestinationKind {
  SLACK
  LINEAR
  JIRA
  WEBHOOK
}

model Destination {
  id          String          @id @default(cuid())
  orgId       String
  org         Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind        DestinationKind
  name        String
  // KMS-encrypted JSON config. Shape depends on kind: SLACK { botToken,
  // defaultChannel }; LINEAR { apiKey, teamId }; JIRA { baseUrl, email,
  // apiToken, projectKey, issueType }; WEBHOOK { url, secret }.
  ciphertext  Bytes
  iv          Bytes
  keyId       String
  // Auto-issue rule: when set, findings at or above this severity are
  // automatically dispatched to this destination. null = manual only.
  autoSeverity String?
  // Channel routing (SLACK only); per-severity overrides take precedence.
  routingJson  Json?
  enabled     Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  dispatches DestinationDispatch[]

  @@index([orgId])
  @@index([projectId])
}

enum DispatchStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

model DestinationDispatch {
  id            String         @id @default(cuid())
  destinationId String
  destination   Destination    @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  findingId     String
  finding       Finding        @relation(fields: [findingId], references: [id], onDelete: Cascade)
  status        DispatchStatus @default(QUEUED)
  externalId    String?        // Slack ts, Linear issue id, Jira key
  externalUrl   String?
  errorMessage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([destinationId, findingId])
  @@index([findingId])
  @@index([status])
}

// ── Phase 3: audit log ──────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // Actor — user, or null for system actions (webhooks, cron).
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Stable verb (see packages/shared/src/audit.ts).
  action    String
  // What was operated on, e.g. "scan", "credential", "destination".
  targetKind String?
  targetId  String?
  // Redacted JSON payload — the writer strips sensitive keys before logging.
  payload   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([targetKind, targetId])
}

// ── Phase 3: SSO ────────────────────────────────────────────────────────────

enum SsoProtocol {
  SAML
  OIDC
}

model SsoConnection {
  id          String      @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  protocol    SsoProtocol
  // External identifier from the SSO provider (e.g. WorkOS connection_id).
  externalId  String      @unique
  // KMS-encrypted config (idp metadata, client secret, etc.).
  ciphertext  Bytes
  iv          Bytes
  keyId       String
  domain      String?
  enabled     Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([orgId])
}
