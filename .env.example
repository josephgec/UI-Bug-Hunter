# Postgres
DATABASE_URL=postgresql://ubh:ubh@localhost:5432/ubh?schema=public

# Redis (used for the job queue)
REDIS_URL=redis://localhost:6379

# Web app
WEB_PORT=3000
DEV_USER_EMAIL=dev@local.test

# LLM provider — one of: mock | anthropic | openai
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Worker
WORKER_CONCURRENCY=1
SCAN_MAX_TOOL_CALLS=40
SCAN_MAX_WALL_TIME_MS=120000

# Where the worker writes screenshots / DOM snapshots in dev (S3 in prod, later)
ARTIFACT_DIR=./.scan-artifacts
