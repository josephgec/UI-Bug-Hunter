# Postgres
DATABASE_URL=postgresql://ubh:ubh@localhost:5432/ubh?schema=public

# Redis (used for the scan + crawl queues)
REDIS_URL=redis://localhost:6379

# Web app
WEB_PORT=3000
DEV_USER_EMAIL=dev@local.test

# LLM provider — one of: mock | anthropic | openai | ollama
#
# Ollama (local inference) requires a model with vision + tool calling.
# Pull one with `ollama pull <model>`. Recommended by hardware tier:
#   16-32 GB:  llama3.2-vision:11b      (~7 GB,  fastest, broad support)
#   32-48 GB:  qwen2.5vl:32b            (~22 GB, best speed/quality balance)
#   48-64 GB:  qwen2.5vl:72b            (~45 GB) OR llama3.2-vision:90b (~50 GB)
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434

# Worker
WORKER_CONCURRENCY=1
SCAN_MAX_TOOL_CALLS=40
SCAN_MAX_WALL_TIME_MS=120000

# Billing — one of: mock | stripe
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_BUSINESS=
STRIPE_METERED_ITEM_ID=

# KMS — one of: local | aws
KMS_PROVIDER=local
# At least 16 characters. Generate one with `openssl rand -hex 32`.
KMS_LOCAL_KEY=replace-me-with-a-secret-of-at-least-16-chars
AWS_KMS_KEY_ID=

# Where the worker writes screenshots / DOM snapshots in dev (S3 in prod)
ARTIFACT_DIR=./.scan-artifacts

# Public dashboard URL — used by the destinations dispatcher to embed a
# clickable link in Slack / Linear / Jira issues created from findings.
PUBLIC_DASHBOARD_URL=http://localhost:3000

# SSO — one of: mock | workos
SSO_PROVIDER=mock
SSO_STATE_SECRET=replace-me-with-a-32-byte-secret-from-openssl-rand
SSO_MOCK_SECRET=dev-mock-secret-1234567890
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# Destinations — set FOO_PROVIDER=mock to short-circuit external calls in dev.
SLACK_PROVIDER=
LINEAR_PROVIDER=
JIRA_PROVIDER=
