# Postgres
DATABASE_URL=postgresql://ubh:ubh@localhost:5432/ubh?schema=public

# Redis (used for the scan + crawl queues)
REDIS_URL=redis://localhost:6379

# Web app
WEB_PORT=3000
DEV_USER_EMAIL=dev@local.test

# LLM provider — one of: mock | anthropic | openai
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Worker
WORKER_CONCURRENCY=1
SCAN_MAX_TOOL_CALLS=40
SCAN_MAX_WALL_TIME_MS=120000

# Billing — one of: mock | stripe
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_BUSINESS=
STRIPE_METERED_ITEM_ID=

# KMS — one of: local | aws
KMS_PROVIDER=local
# At least 16 characters. Generate one with `openssl rand -hex 32`.
KMS_LOCAL_KEY=replace-me-with-a-secret-of-at-least-16-chars
AWS_KMS_KEY_ID=

# Where the worker writes screenshots / DOM snapshots in dev (S3 in prod)
ARTIFACT_DIR=./.scan-artifacts
